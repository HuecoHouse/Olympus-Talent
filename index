<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Olympus Talent & Entertainment — Coming Soon</title>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">

<style>

*,*::before,*::after{
box-sizing:border-box;
margin:0;
padding:0;
}

:root{
--gold:#ceb17e;
--gold-light:#dcc49a;
--black:#282828;
--dark:#222222;
--white:#f7f7f7;
--gray:#999999;
}

body{
background:var(--black);
color:var(--white);
font-family:'Montserrat',sans-serif;
min-height:100vh;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
text-align:center;
padding:2rem;
overflow:hidden;
position:relative;
}

body::before{
content:'';
position:fixed;
inset:0;
background:radial-gradient(ellipse at 50% 50%,rgba(206,177,126,0.05) 0%,transparent 65%);
pointer-events:none;
}

.container{
max-width:560px;
width:100%;
display:flex;
flex-direction:column;
align-items:center;
position:relative;
z-index:1;
}

.logo{
width:280px;
max-width:80vw;
margin-bottom:2.5rem;
}

.divider{
width:40px;
height:1px;
background:var(--gold);
margin-bottom:2rem;
opacity:0.6;
}

.coming-label{
font-size:.6rem;
letter-spacing:.45em;
text-transform:uppercase;
color:var(--gold);
margin-bottom:1rem;
}

h1{
font-family:'Cormorant Garamond',serif;
font-size:clamp(1.8rem,5vw,3rem);
font-weight:300;
letter-spacing:.08em;
line-height:1.3;
margin-bottom:1rem;
color:var(--white);
}

.sub{
color:var(--gray);
font-size:.78rem;
line-height:1.9;
margin-bottom:2.5rem;
letter-spacing:.03em;
}

.form-wrap{
width:100%;
display:flex;
gap:0;
margin-bottom:1rem;
}

.form-wrap input{
flex:1;
background:rgba(247,247,247,.04);
border:1px solid rgba(206,177,126,.3);
border-right:none;
color:var(--white);
padding:.85rem 1.2rem;
font-family:'Montserrat',sans-serif;
font-size:.75rem;
outline:none;
transition:border-color .3s;
letter-spacing:.03em;
}

.form-wrap input::placeholder{
color:var(--gray);
}

.form-wrap input:focus{
border-color:var(--gold);
}

.form-wrap button{
background:var(--gold);
color:var(--black);
border:none;
padding:.85rem 1.6rem;
font-family:'Montserrat',sans-serif;
font-size:.6rem;
font-weight:600;
letter-spacing:.2em;
text-transform:uppercase;
cursor:pointer;
transition:background .3s;
white-space:nowrap;
}

.form-wrap button:hover{
background:var(--gold-light);
}

.form-note{
font-size:.62rem;
color:var(--gray);
letter-spacing:.05em;
opacity:.7;
}

.success-msg{
display:none;
color:var(--gold);
font-size:.72rem;
letter-spacing:.15em;
text-transform:uppercase;
padding:.85rem;
border:1px solid rgba(206,177,126,.3);
width:100%;
text-align:center;
}

.contact-row{
display:flex;
gap:2rem;
margin-top:3rem;
flex-wrap:wrap;
justify-content:center;
}

.contact-item .label{
font-size:.55rem;
letter-spacing:.3em;
text-transform:uppercase;
color:var(--gold);
margin-bottom:.3rem;
}

.contact-item a{
color:var(--gray);
font-size:.72rem;
text-decoration:none;
transition:color .3s;
letter-spacing:.03em;
}

.contact-item a:hover{
color:var(--white);
}

.footer{
position:fixed;
bottom:1.5rem;
font-size:.58rem;
color:rgba(247,247,247,.2);
letter-spacing:.15em;
text-transform:uppercase;
}

</style>
</head>

<body>

<div class="container">

<img class="logo"
src="https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/69a7b00ac3a5d76378be7804/f17893ea6_LogoT14x.png"
alt="Olympus Talent & Entertainment">

<div class="divider"></div>

<p class="coming-label">Coming Soon</p>

<p class="sub">
We're putting the finishing touches on something big.
Drop your email and be the first to know when we launch.
</p>

<form class="form-wrap" onsubmit="handleSubmit(event)">
<input type="email" placeholder="Your email address" required>
<button type="submit">Notify Me</button>
</form>

<div class="success-msg" id="success">
You're on the list. We'll be in touch. ✦
</div>

<p class="form-note">No spam. Just the big news.</p>

<div class="contact-row">

<div class="contact-item">
<p class="label">Email</p>
<a href="mailto:contact@olympustalent.us">contact@olympustalent.us</a>
</div>

<div class="contact-item">
<p class="label">Phone</p>
<a href="tel:7146734033">714-673-4033</a>
</div>

</div>
</div>

<p class="footer">© 2025 Olympus Talent & Entertainment</p>

<script>
function handleSubmit(e){
e.preventDefault();
const form=e.target;
const success=document.getElementById('success');
form.style.display='none';
success.style.display='block';
}
</script>

</body>
</html>
